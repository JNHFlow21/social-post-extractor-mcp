# Core
ASR_PROVIDER=volcengine_speech
VISION_PROVIDER=doubao
CLEAN_PROVIDER=doubao

# Volcengine Speech ASR
VOLCENGINE_SPEECH_APP_ID=your_volcengine_app_id
VOLCENGINE_SPEECH_ACCESS_TOKEN=your_volcengine_access_token
VOLCENGINE_SPEECH_RESOURCE_ID=volc.seedasr.sauc.duration
VOLCENGINE_SPEECH_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
VOLCENGINE_SPEECH_MODEL_NAME=bigmodel

# Doubao Vision / Cleanup
ARK_API_KEY=your_ark_api_key
VISION_MODEL=doubao-1-5-vision-pro-32k-250115
CLEAN_MODEL=doubao-1-5-pro-32k-250115

# Optional alternate providers
# SILICONFLOW_API_KEY=
# DASHSCOPE_API_KEY=
# BAILIAN_API_KEY=
# MINIMAX_API_KEY=
# OPENAI_API_KEY=
